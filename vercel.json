{
  "version": 3,
  "buildCommand": "npm run vercel-build",
  "functions": {
    ".vercel_build_output/functions/ssr.func/index.mjs": {
      "runtime": "nodejs"
    }
  },
  "routes": [
    { "handle": "filesystem" },
    { "src": "/.*", "dest": "/.vercel_build_output/functions/ssr.func/index.mjs" }
  ]
}
